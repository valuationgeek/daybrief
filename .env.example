# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored and loaded automatically by agent/config.py.
# The config YAML files reference these via ${VAR} placeholders —
# leave blank any service you don't use.

# ── Email (only if email.enabled) ────────────────────────────────
# Gmail App Password for SMTP (https://myaccount.google.com/apppasswords)
DAYBRIEF_SMTP_PASSWORD=
# SendGrid API key (only if email.provider is "sendgrid")
SENDGRID_API_KEY=

# ── Telegram (only if telegram.enabled) ──────────────────────────
# Bot token from @BotFather; chat ID from @userinfobot
DAYBRIEF_TELEGRAM_BOT_TOKEN=
DAYBRIEF_TELEGRAM_CHAT_ID=

# ── LLM (only if llm.provider is "openai") ───────────────────────
# API key for your OpenAI-compatible endpoint (OpenAI, OpenRouter, Groq, …)
OPENAI_API_KEY=

# ── News APIs (optional — RSS works without any of these) ────────
# New York Times API key (https://developer.nytimes.com)
NYT_API_KEY=

# NewsData.io API key (https://newsdata.io)
NEWSDATA_API_KEY=
